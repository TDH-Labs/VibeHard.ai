node_modules/
dist/
*.tgz

# Gate run artifacts (scanner JSON, evidence, sentinels)
.gate/
.vibehard/

# Logs / scratch
*.log
!fixtures/build-logs/*.log
.DS_Store

# Autonomous loop runtime (scripts/loop-run.sh): single-run lock + per-run telemetry.
# LOOP_NOTES.md (committed milestone journal) and LOOP_BACKLOG.md are NOT ignored.
.loop/
.loop.lock/

# Local env / secrets — never commit
.env
.env.*
!.env.example

# Operator-private prototype source + session transcripts carried for local
# archaeology (see reference/PROVENANCE.md). Contains business/legal skills and
# machine paths — kept on disk for the local session, never committed. Scrub
# before publishing any of it.
reference/

# Release stamp — generated by scripts/release.sh, baked into images, never committed
.build-sha
