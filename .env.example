# VibeHard operator secrets — copy to .env (gitignored) and fill in. NEVER commit real values.
# Naming matters: the substrate reads these exact names. Don't collapse distinct keys.

# ─── Master encryption passphrase (REQUIRED — the web server refuses to boot without it) ──
# NOT from any provider — you generate this yourself, ONCE. It encrypts the per-app
# secrets store (LocalEncryptedSecretsStore, AES-256-GCM). Store it somewhere SEPARATE
# from the encrypted data it protects (it's the key-that-encrypts-the-keys).
# MUST be ≥32 chars and high-entropy; there is NO default (audit B-5 — a committed default
# would make every deployment's keychain decryptable from source).
#   generate with:  openssl rand -base64 32
VIBEHARD_SECRETS_KEY=

# ─── Deploy-sentinel signing key (REQUIRED in production) ─────────────────────
# HMAC key that authenticates the .gate/HARD_VERIFY_PASS deploy sentinel (audit C-1/C3).
# Without it the orchestrator falls back to a dev key and a forged sentinel could authorize
# a deploy. Generate a distinct value from VIBEHARD_SECRETS_KEY.
#   generate with:  openssl rand -hex 32
VIBEHARD_SENTINEL_SECRET=

# ─── Durable state (EPIC #33) — tenants, deployment records, encrypted app secrets ────
# Without this, the web server falls back to embedded disk-persisted Postgres under
# ~/.vibehard/db (or VIBEHARD_DB_DIR) — durable on a persistent disk, but WIPED on an
# ephemeral cloud box (most PaaS containers) unless that path is on a mounted volume.
# Set a real managed Postgres (Neon/Supabase/Fly PG/RDS/…) for any host without a
# persistent volume — otherwise every signup + deployed app is lost on restart/redeploy.
DATABASE_URL=
# VIBEHARD_DB_DIR=~/.vibehard/db   # override the embedded-mode data dir (only used when DATABASE_URL is unset)

# ─── LLM provider (one of; resolution order: openrouter → opencode → anthropic) ──
OPENROUTER_API_KEY=              # sk-or-v1-… from openrouter.ai/keys — the current default gateway
# OPENCODE_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Supabase — distinct credentials, do not merge into one var ──────────────
SUPABASE_URL=                  # public; ships to the browser (https://<ref>.supabase.co)
SUPABASE_ANON_KEY=             # sb_publishable_… — public BY DESIGN, safe ONLY because RLS gates every row
SUPABASE_SERVICE_ROLE_KEY=     # 🔴 sb_secret_… — BYPASSES RLS. Server-side only. Never in a client bundle or the deployed app's env.
# Database (for applying migrations). The DB password is shown ONCE at project creation —
# if you don't have it, reset it: Settings → Database → Reset database password.
SUPABASE_DB_PASSWORD=          # the Postgres password (NOT an API key; different page entirely)
SUPABASE_DB_HOST=              # the POOLER host: aws-<N>-<region>.pooler.supabase.com (IPv4; the direct db.<ref> host is IPv6-only). Leave blank to use the direct connection.
# SUPABASE_DB_PORT=5432        # session pooler / direct = 5432; transaction pooler = 6543
# Managed provisioning (VibeHard Cloud — auto-CREATE a Supabase project per app, vs adopting the one above):
# 🔴 REQUIRED for the web platform: Platform.deployForTenant() FORCES managed mode for every
# tenant deploy (each tenant gets their own auto-provisioned project) — without this token, a
# real user's FIRST deploy throws "SupabaseManagementClient: missing SUPABASE_ACCESS_TOKEN" and
# fails outright. Only optional for the standalone CLI adopting a single SUPABASE_URL project.
SUPABASE_ACCESS_TOKEN=         # Management API PAT (sbp_…) from supabase.com/dashboard/account/tokens. SUPABASE_PAT is accepted as an alias.
# SUPABASE_ORG_ID=             # org to create projects in — optional; the SOLE org is auto-discovered
# VIBEHARD_MANAGED=1            # opt in: `ship` CREATES a fresh project per app (needs the PAT) instead of adopting SUPABASE_URL

# ─── Host / deploy ───────────────────────────────────────────────────────────
VERCEL_TOKEN=                  # deploy leg for JS/TS apps (Vercel HostProvider)
VERCEL_SCOPE=                  # team slug (e.g. tdh-labs) — REQUIRED if the token is team-scoped; blank for a personal account
# Container deploy (Fly HostProvider) — deploys any Dockerfile (Python/Go/…):
FLY_API_TOKEN=                 # from `fly tokens create org -o personal` — QUOTE it if it begins with "FlyV1 " (has a space)
# FLY_ORG=personal             # default: personal
# FLY_REGION=iad               # default: iad (US East)

# ─── Human layer (§24 — deferred, not on the critical path yet) ──────────────
# GITHUB_PAT=                  # fine-grained, scoped to the escalation repo only
# SLACK_BOT_TOKEN=             # from a Slack app created BY MANIFEST (see notes)

# ── Clerk auth (EPIC #34) — set BOTH to switch the product onto Clerk ──────────
# When both are present, Clerk verifies every session (server: @clerk/backend) and ClerkJS drives the
# UI; the legacy email/password + social-login endpoints are disabled. With neither, the legacy auth
# stays active. Get the pk_/sk_ pair from the Clerk dashboard (API keys) or `clerk init`. Same key
# values regardless of framework — store them under these plain names.
CLERK_PUBLISHABLE_KEY=         # pk_test_… (dev) / pk_live_… (prod) — public, safe in the browser
CLERK_SECRET_KEY=              # 🔴 sk_test_… / sk_live_… — server only, NEVER in client code

# ── Stripe billing (EPIC #36 — platform subscriptions, /api/billing/checkout + /webhook) ──
# Code is fully built + wired in web/server.ts; billing stays a no-op until STRIPE_SECRET_KEY
# is set. See docs/BILLING_AND_HOSTING_SETUP.md for the full operator setup (Stripe dashboard
# steps, webhook registration, `stripe listen` for local testing).
STRIPE_SECRET_KEY=             # sk_test_… (the client refuses sk_live_ unless explicitly overridden)
STRIPE_WEBHOOK_SECRET=         # whsec_… — from the webhook endpoint you register at /api/billing/webhook; without
                                # it the webhook 503s, so a paying customer's plan never syncs from Stripe
VIBEHARD_STRIPE_PRICE_MAP=     # JSON: {"price_abc":"starter","price_def":"pro"} — maps Stripe price ids to plans.ts keys
# STRIPE_CONNECT_CLIENT_ID=    # ca_… — only for "Connect Stripe" (a TENANT's generated app accepting payments), not platform billing

# ── Legacy social sign-in (only used when Clerk is NOT configured; see docs/OAUTH_SETUP.md) ──
# Register callback http://localhost:4100/auth/<provider>/callback, then fill these:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# BASE_URL=http://localhost:4100   # override for a public domain
